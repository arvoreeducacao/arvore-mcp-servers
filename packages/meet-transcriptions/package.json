{
	"name": "@arvoretech/meet-transcriptions-mcp",
	"version": "1.0.0",
	"description": "MCP server for semantic search across meeting transcriptions generated by Meet Transcriber",
	"main": "dist/index.js",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"meet-transcriptions-mcp": "./dist/index.js"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:cov": "vitest run --coverage",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix"
	},
	"dependencies": {
		"@lancedb/lancedb": "^0.26.2",
		"@modelcontextprotocol/sdk": "~1.22.0",
		"@xenova/transformers": "^2.17.2",
		"zod": "^3.22.4"
	},
	"devDependencies": {
		"@types/node": "^20.10.0",
		"@vitest/coverage-v8": "^1.0.0",
		"tsx": "^4.6.0",
		"typescript": "^5.3.0",
		"vitest": "^1.0.0"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"meet-transcriptions",
		"semantic-search",
		"arvore"
	],
	"author": "Arvore",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
