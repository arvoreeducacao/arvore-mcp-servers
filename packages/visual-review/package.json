    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.0.0",
    "sharp": "^0.33.0",
    "zod": "^3.22.4"
