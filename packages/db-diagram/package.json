  "author": "Arvore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arvoreeducacao/arvore-mcp-servers.git",
    "directory": "packages/db-diagram"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.22.0",
    "zod": "^3.22.4"
  }
}
