{
  "name": "@arvoretech/whatsapp-mcp",
  "version": "0.1.0",
  "description": "WhatsApp MCP Server using Baileys for sending and reading messages from a single WhatsApp account",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "whatsapp-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:cov": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": [
    "mcp",
    "whatsapp",
    "baileys",
    "messaging",
    "arvore"
  ],
  "author": "Arvore",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arvoreeducacao/arvore-mcp-servers.git",
    "directory": "packages/whatsapp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.22.0",
    "baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.9.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2"
  }
}
